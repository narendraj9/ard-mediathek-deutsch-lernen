{
    "manifest_version": 3,
    "name": "ARD Mediathek Subtitle Translator",
    "version": "1.0",
    "description": "Translates ARD Mediathek subtitles to English inside the video player.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://translate.googleapis.com/",
        "https://api.groq.com/",
        "https://api.cerebras.ai/"
    ],
    "content_scripts": [
        {
            "matches": [
              "https://www.ardmediathek.de/video/*",
              "https://www.ardmediathek.de/live/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "style.css"
            ]
        }
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "bilingual-ard@narendraj9.github.io",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
