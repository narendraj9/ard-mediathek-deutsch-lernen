{
    "manifest_version": 3,
    "name": "ARD Mediathek Subtitle Translator",
    "version": "1.0",
    "description": "Translates ARD Mediathek subtitles to English inside the video player.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://translate.googleapis.com/",
        "https://api.groq.com/"
    ],
    "content_scripts": [
        {
            "matches": [
              "https://www.ardmediathek.de/video/*",
              "https://www.ardmediathek.de/live/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "style.css"
            ]
        }
    ],
    "background": {
        "service_worker": "background.js",
        "scripts": [
            "background.js"
        ]
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "bilingual-ard@futurk.me"
        }
    }
}
