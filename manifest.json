{
    "manifest_version": 3,
    "name": "Bilingual Subtitles",
    "version": "1.2",
    "description": "Bilingual subtitle helper for language learners. Works on ARD Mediathek and Netflix.",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://translate.googleapis.com/",
        "https://api.groq.com/",
        "https://api.cerebras.ai/"
    ],
    "content_scripts": [
        {
            "matches": [
              "https://www.ardmediathek.de/video/*",
              "https://www.ardmediathek.de/live/*",
              "https://www.netflix.com/watch/*",
              "https://www3.stage.netflix.com/watch/*",
              "https://www.youtube.com/*",
              "https://m.youtube.com/*",
              "https://www.arte.tv/*",
              "https://www.zdf.de/*"
            ],
            "js": [
                "sites.js",
                "content.js"
            ],
            "css": [
                "style.css"
            ]
        }
    ],
    "background": {
        "scripts": [
            "background.js"
        ]
    },
    "options_ui": {
        "page": "options.html",
        "open_in_tab": false
    },
    "browser_specific_settings": {
        "gecko": {
            "id": "bilingual-ard@narendraj9.github.io",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
